    "def insercion_datos_artistas (nombre_fichero, contraseña):\n",
    "\n",
    "    artistas = []\n",
    "\n",
    "    with open(nombre_fichero, \"r\",encoding=\"utf-8\") as fichero:  \n",
    "        lastfm_artistas = json.load(fichero)\n",
    "\n",
    "    for nombre,x in lastfm_artistas.items(): # nombre es la key de nuestro diccionario y x es value\n",
    "        artistas.append([\n",
    "            nombre,\n",
    "            x[\"biografia\"],\n",
    "            x[\"listeners\"],\n",
    "            x[\"similares\"], #texto_base64\n",
    "            x[\"playcount\"]]\n",
    "        )\n",
    "    \n",
    "    cnx = mysql.connector.connect(user=\"root\",\n",
    "                              password = contraseña,\n",
    "                              host=\"127.0.0.1\",\n",
    "                              database= \"music_stream\",\n",
    "                              charset='utf-8', # para el formato de caracteres\n",
    "                              read_timeout=300,\n",
    "                              write_timeout=300)\n",
    "\n",
    "    cursor = cnx.cursor()\n",
    "\n",
    "    sql_artistas = \"\"\"\n",
    "    INSERT INTO artistas (nombre, biografia,listeners,similares,playcount)\n",
    "    VALUES (%s, %s, %s, %s, %s)\n",
    "    \"\"\"\n",
    "    \n",
    "    artistas_insertados = 0\n",
    "\n",
    "    for a in artistas:\n",
    "        try:\n",
    "            cursor.execute(sql_artistas,a)\n",
    "            print(a[1]) #1 sería el nombre\n",
    "        except:\n",
    "            #si hay un error, para, no sigas.\n",
    "            cnx.rollback()\n",
    "            print(f\"Hay un error en la inserción de {a[0]}\")\n",
    "        else:\n",
    "            cnx.commit()\n",
    "            print(\"commit realizado\")\n",
    "            artistas_insertados+=1\n",
    "        finally:\n",
    "            print(\"proceso terminado\")\n",
    "    print(\"Artistas insertados --->\", artistas_insertados)\n",
    "\n",
    "    cursor.close()\n",
    "    print(\"Se ha cerrado la conexión al servidor\")"
   ]
  },
